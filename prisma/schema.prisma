generator client {
  provider = "prisma-client"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  books     Book[]
  calendarEventsCreated CalendarEvent[] @relation("CalendarEventCreatedBy")

  @@index([email], map: "user_email_idx")
}

model Book {
  id          String  @id @default(cuid())
  owner       User    @relation(fields: [ownerId], references: [id])
  ownerId     String
  title       String
  author      String?
  description String?
  url         String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([id, ownerId], map: "book_owner_idx")
}

model CalendarEvent {
  id            String   @id @default(cuid())
  googleEventId String   @unique
  calendarId    String

  summary     String
  description String?
  location    String?

  startAt DateTime
  endAt   DateTime
  timeZone String?

  createdBy   User?   @relation("CalendarEventCreatedBy", fields: [createdById], references: [id])
  createdById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([calendarId, startAt], map: "calendar_event_calendar_start_idx")
  @@index([createdById], map: "calendar_event_created_by_idx")
}
